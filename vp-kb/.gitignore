# Dependency directories
node_modules/

# Files generated by VitePress
docs/.vitepress/dist/
docs/.vitepress/cache/
dist/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS metadata
.DS_Store
Thumbs.db

# --- 核心同步策略 ---
# 我们忽略 docs 下所有自动生成的内容，因为 GitHub Actions 会自动运行 sync 脚本生成它们。
# 这保证了你的 Git 仓库非常干净，只包含 obsidian-notes 中的原始笔记。
docs/*
!docs/.vitepress/
docs/.vitepress/sidebar-gen.ts

# 不忽略重要的项目配置文件
!tsconfig.json
!package.json
!pnpm-lock.yaml

# 忽略 Obsidian 的本地私有配置
obsidian-notes/.obsidian/
obsidian-notes/.trash/
obsidian-notes/.sync/
